# ─── Server ───────────────────────────────────────────────────────
# PORT behaviour:
#   3000  → local development (default, no entry needed)
#   80    → production HTTP
#   443   → production HTTPS  (place cert.pem + key.pem in ./certs/)
#   (unset) → cloud platforms inject PORT automatically
PORT=3000

# ─── Port assignments (managed by port-mapper.js) ─────────────────
# Run `node port-mapper.js` to auto-detect conflicts and write port-assignments.json.
# Override individual service ports here if needed.
CONTAINERX_PORT=3001      # Xcontainerx/server.js — moved off 3000 to avoid conflict with system.js
PORT_MAPPER_PORT=3999     # port-mapper service itself

# ─── Environment ──────────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production

# ─── HTTPS (only needed when PORT=443) ───────────────────────────
# HTTPS=true
# SSL_CERT=./certs/cert.pem
# SSL_KEY=./certs/key.pem

# ─── Cloud platform notes ─────────────────────────────────────────
# Heroku  → PORT injected automatically, do NOT set here
# Railway → PORT injected automatically, do NOT set here
# Render  → PORT=10000 injected automatically
# Fly.io  → PORT=8080  injected automatically

# ─── Mail — Brevo primary + Gmail backup ──────────────────────────
# Brevo SMTP (primary — high deliverability, SPF/DKIM managed by Brevo)
#   1. Sign up at brevo.com
#   2. Go to: Brevo → SMTP & API → SMTP → Generate a new SMTP key
#   3. Verify your sender address/domain in Brevo Senders & Domains
BREVO_SMTP_USER=your@email.com
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM=noreply@bridge-ai-os.com
BREVO_FROM_NAME=Bridge AI OS

# Gmail backup (used only if Brevo fails)
#   1. Enable 2FA on your Google account
#   2. Go to: myaccount.google.com → Security → App passwords
#   3. Generate a password for "Mail" + "Other (Bridge AI OS)"
GMAIL_USER=your@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ─── WordPress Multi-Domain Sync ──────────────────────────────────
# Pushes 50-applications content to WP sites via REST API.
# Generate App Passwords: WP Admin → Users → Profile → Application Passwords
# Docs: https://developer.wordpress.org/rest-api/using-the-rest-api/authentication/
#
# Site: bridge-ai-os.com
WP_BRIDGE_AI_OS_URL=https://bridge-ai-os.com
WP_BRIDGE_AI_OS_USER=admin
WP_BRIDGE_AI_OS_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
#
# Site: gateway.ai-os.co.za
WP_GATEWAY_URL=https://gateway.ai-os.co.za
WP_GATEWAY_USER=admin
WP_GATEWAY_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
