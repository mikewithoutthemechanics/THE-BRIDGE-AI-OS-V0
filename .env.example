# ─── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Port assignments (managed by port-mapper.js) ─────────────────
CONTAINERX_PORT=3001
PORT_MAPPER_PORT=3999

# ─── Supabase (production PostgreSQL) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_ANON_KEY=eyJ...your-anon-key

# ─── Postgres (local dev fallback) ────────────────────────────────
DATABASE_URL=postgresql://bridge:change-me-in-production@localhost:5432/bridge

# ─── SMTP — Primary Mail ─────────────────────────────────────────
SMTP_HOST=mail.your-domain.com
SMTP_PORT=587
SMTP_USER=admin@your-domain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=admin@your-domain.com
SMTP_FROM_NAME=Bridge AI OS
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=false

# ─── Brevo (backup SMTP relay) ───────────────────────────────────
BREVO_SMTP_USER=your@email.com
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxxxxxxxxxx
BREVO_FROM=noreply@your-domain.com
BREVO_FROM_NAME=Bridge AI OS

# ─── Gmail (tertiary backup) ─────────────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ─── PayFast (Payment Processing) ────────────────────────────────
PAYFAST_MERCHANT_ID=00000000
PAYFAST_MERCHANT_KEY=xxxxxxxxxxxx
PAYFAST_PASSPHRASE=CHANGE_ME
PAYFAST_NOTIFY_URL=https://your-domain.com/payfast/notify
PAYFAST_RETURN_URL=https://your-domain.com/payment/success
PAYFAST_CANCEL_URL=https://your-domain.com/payment/cancel

# ─── AI Provider Keys ────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
KILO_API_KEY=
LLM_PROVIDER_ORDER=kilo,anthropic,openrouter,openai

# ─── Auth & Security (rotate every 90 days) ──────────────────────
# Generate with: openssl rand -hex 48
JWT_SECRET=CHANGE_ME
# Generate with: openssl rand -hex 16
BRIDGE_INTERNAL_SECRET=CHANGE_ME
# Simple admin token — use a real auth system in production
ADMIN_TOKEN=CHANGE_ME

# ─── Brain Identity ──────────────────────────────────────────────
BRAIN_ADMIN_EMAIL=admin@your-domain.com
BRAIN_ADMIN_NAME=Mr. Myburg
BRAIN_IDENTITY=mr-myburg

# ─── WordPress Multi-Domain Sync ─────────────────────────────────
WP_BRIDGE_AI_OS_URL=https://bridge-ai-os.com
WP_BRIDGE_AI_OS_USER=admin
WP_BRIDGE_AI_OS_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
WP_GATEWAY_URL=https://gateway.ai-os.co.za
WP_GATEWAY_USER=admin
WP_GATEWAY_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx
WP_HOOK_SECRET=CHANGE_ME

# ─── WordPress.com ────────────────────────────────────────────────
WP_URL=https://bridgeaios.wordpress.com
WP_USERNAME=your@email.com
WP_APP_PASSWORD=CHANGE_ME
WP_COM_URL=https://public-api.wordpress.com/wp/v2/sites/bridgeaios.wordpress.com
WP_COM_USER=your@email.com
WP_COM_APP_PASS=CHANGE_ME

# ─── Linea / Ethereum (SIWE + Contract Deployment) ───────────────
BRIDGE_SIWE_RPC_URL=https://rpc.linea.build
BRIDGE_SIWE_CHAIN_ID=59144
# Generate with: openssl rand -hex 32
BRIDGE_SIWE_JWT_SECRET=CHANGE_ME

# Contract deployer wallet private key (NEVER share this)
# Export from MetaMask: Account Details -> Export Private Key
DEPLOYER_PRIVATE_KEY=CHANGE_ME
# Treasury address receives the initial 10M BRDG mint
TREASURY_ADDRESS=0xYourTreasuryAddress

# ─── Clerk Authentication ────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cloudflare (optional) ───────────────────────────────────────
CF_API_TOKEN=
CF_ZONE_ID=

# ─── DirectAdmin (optional) ──────────────────────────────────────
DA_BASE_URL=https://your-server:2222
DA_USERNAME=
DA_LOGIN_KEY=
