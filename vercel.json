{
  "version": 2,
  "framework": null,
  "buildCommand": "node build-static.js",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "shared/**,port-assignments.json,agents/**,certs/**,lib/**"
    }
  },
  "crons": [
    { "path": "/api/agents/auto",       "schedule": "0 */6 * * *" },
    { "path": "/api/infra/auto",        "schedule": "0 */1 * * *" },
    { "path": "/api/banks/compound",    "schedule": "0 0 * * *"   },
    { "path": "/api/treasury/reconcile","schedule": "0 */3 * * *" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "ehsa.ai-os.co.za" }],
      "destination": "/ehsa",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "hospitalinabox.ai-os.co.za" }],
      "destination": "/hospital",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "aid.ai-os.co.za" }],
      "destination": "/aid",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "rootedearth.ai-os.co.za" }],
      "destination": "/rootedearth",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "aurora.ai-os.co.za" }],
      "destination": "/aurora",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "ubi.ai-os.co.za" }],
      "destination": "/ubi",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/apps",          "destination": "/50-applications.html" },
    { "source": "/treasury-dash", "destination": "/aoe-dashboard.html" },
    { "source": "/dashboard",     "destination": "/aoe-dashboard.html" },
    { "source": "/status",        "destination": "/system-status-dashboard.html" },
    { "source": "/ban",           "destination": "/ban-home.html" },
    { "source": "/ehsa",          "destination": "/ehsa-app.html" },
    { "source": "/supac",         "destination": "/supac-home.html" },
    { "source": "/ubi",           "destination": "/ubi-home.html" },
    { "source": "/aid",           "destination": "/aid-home.html" },
    { "source": "/aurora",        "destination": "/aurora-home.html" },
    { "source": "/twins",         "destination": "/digital-twin-console.html" },
    { "source": "/executive",     "destination": "/executive-dashboard.html" },
    { "source": "/face",          "destination": "/anatomical_face.html" },
    { "source": "/hospital",      "destination": "/hospital-home.html" },
    { "source": "/rootedearth",   "destination": "/rootedearth-home.html" },
    { "source": "/abaas",         "destination": "/abaas.html" },
    { "source": "/crm",           "destination": "/crm.html" },
    { "source": "/invoicing",     "destination": "/invoicing.html" },
    { "source": "/legal",         "destination": "/legal.html" },
    { "source": "/marketing",     "destination": "/marketing.html" },
    { "source": "/tickets",       "destination": "/tickets.html" },
    { "source": "/pricing",       "destination": "/pricing.html" },
    { "source": "/leadgen",       "destination": "/leadgen.html" },
    { "source": "/control",       "destination": "/control.html" },
    { "source": "/registry",      "destination": "/registry.html" },
    { "source": "/agents",        "destination": "/agents.html" },
    { "source": "/topology",      "destination": "/topology.html" },
    { "source": "/docs",          "destination": "/docs.html" },
    { "source": "/landing",       "destination": "/landing.html" },
    { "source": "/sitemap",       "destination": "/sitemap.html" },
    { "source": "/affiliate",     "destination": "/affiliate.html" },
    { "source": "/governance",    "destination": "/governance.html" },
    { "source": "/auth-dashboard","destination": "/auth-dashboard.html" },
    { "source": "/join",          "destination": "/join.html" },
    { "source": "/welcome",       "destination": "/welcome.html" },
    { "source": "/home",          "destination": "/home.html" },
    { "source": "/settings",      "destination": "/settings.html" },
    { "source": "/marketplace",   "destination": "/marketplace.html" },
    { "source": "/onboarding",    "destination": "/onboarding.html" },
    { "source": "/brand",         "destination": "/brand.html" },
    { "source": "/corporate",     "destination": "/corporate.html" },
    { "source": "/intelligence",  "destination": "/intelligence.html" },
    { "source": "/terminal",      "destination": "/terminal.html" },
    { "source": "/wallet",        "destination": "/wallet.html" },
    { "source": "/trading",       "destination": "/trading.html" },
    { "source": "/defi",          "destination": "/defi.html" },
    { "source": "/avatar",        "destination": "/avatar.html" },
    { "source": "/admin",         "destination": "/admin.html" },
    { "source": "/platforms",     "destination": "/platforms.html" },
    { "source": "/bridge-home",   "destination": "/bridge-home.html" },
    { "source": "/command-center","destination": "/command-center.html" },
    { "source": "/infra",         "destination": "/infra.html" },
    { "source": "/twin-wall",     "destination": "/twin-wall.html" },
    { "source": "/banks",         "destination": "/banks.html" },
    { "source": "/logs",          "destination": "/logs.html" },
    { "source": "/payment",       "destination": "/payment.html" },
    { "source": "/tvm",            "destination": "/tvm.html" },
    { "source": "/api/tvm",        "destination": "/api" },
    { "source": "/api/tvm/:path*", "destination": "/api" },
    { "source": "/skills",        "destination": "/api" },
    { "source": "/skills/:path*", "destination": "/api" },
    { "source": "/telemetry",     "destination": "/api" },
    { "source": "/graph",         "destination": "/api" },
    { "source": "/teach/:path*",  "destination": "/api" },
    { "source": "/run/:path*",    "destination": "/api" },
    { "source": "/live-map",      "destination": "/api" },
    { "source": "/treasury/:path*","destination": "/api" },
    { "source": "/swarm/:path*",  "destination": "/api" },
    { "source": "/econ/:path*",   "destination": "/api" },
    { "source": "/ubi/:path*",    "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/events/stream", "destination": "/api" },
    { "source": "/orchestrator/status", "destination": "/api" },
    { "source": "/billing", "destination": "/api" },
    { "source": "/ask", "destination": "/api" },
    { "source": "/api/l1/:path*", "destination": "/api" },
    { "source": "/api/l2/:path*", "destination": "/api" },
    { "source": "/api/l3/:path*", "destination": "/api" },
    { "source": "/api/treasury/:path*", "destination": "/api" },
    { "source": "/api/agents/dispatch", "destination": "/api" },
    { "source": "/api/agents/queue", "destination": "/api" },
    { "source": "/api/marketplace/tasks/:path*", "destination": "/api" },
    { "source": "/api/users", "destination": "/api" },
    { "source": "/api/events/recent", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/referral/:path*", "destination": "/api" }
  ]
}
